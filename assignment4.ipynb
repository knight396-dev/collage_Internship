    "# 7. Write a Python function to Print Even Numbers from a Given List\n",
    "\n",
    "lst = [1,2,3,4,5,6]\n",
    "\n",
    "def evenOdd(number):\n",
    "    for i in range(len(number)):\n",
    "        if number%2==0:\n",
    "            print(number[i])\n",
    "        else:\n",
    "            pass\n",
    "        \n",
    "        \n",
    "\n",
    "\n",
    "\n",
    "evenOdd(lst)"
   ]
